// server.js
import express from 'express';
import Stripe from 'stripe';
import dotenv from 'dotenv';
import cors from 'cors';

dotenv.config();

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY, { apiVersion: '2023-11-15' });

const app = express();
app.use(cors());
app.use(express.json());

// Mock database
const Database = {
  users: {}, // { email: { customerId, subscriptionId, status } }
  saveUser: function(email, customerId) { this.users[email] = { customerId, status: 'pending' }; },
  updateSubscription: function(email, subscriptionId, status) { this.users[email].subscriptionId = subscriptionId; this.users[email].status = status; },
  getUser: function(email) { return this.users[email]; }
};

// Mock email service
const EmailService = {
  send: async (email, subject, message) => console.log(`Email to ${email}: ${subject} - ${message}`)
};

/**
 * Create Stripe customer + subscription
 */
app.post('/create-subscription', async (req, res) => {
  const { email, priceId, trialDays = 14, couponId } = req.body;
  if (!email || !priceId) return res.status(400).json({ error: 'Email and priceId required' });

  try {
    // Create Stripe customer
    const customer = await stripe.customers.create({ email });
    Database.saveUser(email, customer.id);

    // Create subscription
    const subscriptionParams = {
      customer: customer.id,
      items: [{ price: priceId }],
      payment_behavior: 'default_incomplete',
      expand: ['latest_invoice.payment_intent', 'customer'],
      trial_period_days: trialDays,
      coupon: couponId || undefined
    };

    const subscription = await stripe.subscriptions.create(subscriptionParams);
    const paymentIntent = subscription.latest_invoice.payment_intent;

    Database.updateSubscription(email, subscription.id, subscription.status);

    // If 3D Secure required, return client_secret
    if (paymentIntent.status === 'requires_action') {
      return res.json({ subscriptionId: subscription.id, clientSecret: paymentIntent.client_secret });
    }

    res.json({ subscriptionId: subscription.id, status: subscription.status });
  } catch (err) {
    console.error(err);
    res.status(500).json({ error: 'Failed to create subscription' });
  }
});

/**
 * Stripe webhook
 */
app.post('/webhook', express.raw({ type: 'application/json' }), async (req, res) => {
  const sig = req.headers['stripe-signature'];
  let event;
  try {
    event = stripe.webhooks.constructEvent(req.body, sig, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err) {
    console.error('Webhook signature verification failed:', err.message);
    return res.status(400).send(`Webhook Error: ${err.message}`);
  }

  const data = event.data.object;
  const customerEmail = Object.keys(Database.users).find(email => Database.users[email].customerId === data.customer) || 'unknown@example.com';

  switch (event.type) {
    case 'invoice.payment_succeeded':
      Database.updateSubscription(customerEmail, data.subscription, 'active');
      await EmailService.send(customerEmail, 'Payment Successful', 'Your subscription payment succeeded.');
      break;
    case 'invoice.payment_failed':
      Database.updateSubscription(customerEmail, data.subscription, 'past_due');
      await EmailService.send(customerEmail, 'Payment Failed', 'Please update your payment method to avoid interruption.');
      break;
    case 'customer.subscription.deleted':
      Database.updateSubscription(customerEmail, data.id, 'canceled');
      await EmailService.send(customerEmail, 'Subscription Canceled', 'Your subscription was canceled.');
      break;
    case 'customer.subscription.updated':
      Database.updateSubscription(customerEmail, data.id, data.status);
      break;
    default:
      console.log(`Unhandled event type: ${event.type}`);
  }

  res.json({ received: true });
});

const PORT = process.env.PORT || 4242;
app.listen(PORT, () => console.log(`Server running on port ${PORT}`));
{
  "name": "saas-frontend",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^2.8.0",
    "@stripe/stripe-js": "^2.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^4.4.0"
  }
}
import { defineConfig } from 'vite';
import react from '@vitejs/plugin-react';

export default defineConfig({
  plugins: [react()],
  server: {
    proxy: {
      '/create-subscription': 'http://localhost:4242',
      '/webhook': 'http://localhost:4242'
    }
  }
});
import { useState } from 'react';
import { useStripe, useElements, CardElement } from '@stripe/react-stripe-js';

export default function SubscriptionForm({ priceId }) {
  const stripe = useStripe();
  const elements = useElements();
  const [email, setEmail] = useState('');

  const handleSubmit = async (e) => {
    e.preventDefault();
    const res = await fetch('/create-subscription', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, priceId })
    });
    const data = await res.json();

    if (data.clientSecret) {
      const result = await stripe.confirmCardPayment(data.clientSecret, {
        payment_method: { card: elements.getElement(CardElement) }
      });
      if (result.error) alert(result.error.message);
      else alert('Subscription successful!');
    } else {
      alert('Subscription created successfully!');
    }
  };

  return (
    <form onSubmit={handleSubmit}>
      <input type="email" placeholder="Email" value={email} onChange={e => setEmail(e.target.value)} required />
      <CardElement />
      <button type="submit">Subscribe</button>
    </form>
  );
}
import { loadStripe } from '@stripe/stripe-js';
import { Elements } from '@stripe/react-stripe-js';
import SubscriptionForm from './SubscriptionForm';

const stripePromise = loadStripe('pk_test_YourPublicKey');

export default function App() {
  return (
    <Elements stripe={stripePromise}>
      <SubscriptionForm priceId="price_xxxxxxxxxxxxx" />
    </Elements>
  );
}
import React from 'react';
import ReactDOM from 'react-dom/client';
import App from './App';
import './index.css';

ReactDOM.createRoot(document.getElementById('root')).render(
  <React.StrictMode>
    <App />
  </React.StrictMode>
);
