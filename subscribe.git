// stripe-saas-auto.js
import Stripe from 'stripe';
import express from 'express';
import dotenv from 'dotenv';

dotenv.config();

const stripe = new Stripe(process.env.STRIPE_SECRET_KEY, {
  apiVersion: '2023-11-15',
});

const app = express();
app.use(express.json()); // Parse JSON for webhooks

// Mock database and email notification functions
const Database = {
  updateSubscriptionStatus: async (customerId, subscriptionId, status) => {
    console.log(`DB Update: Customer ${customerId}, Subscription ${subscriptionId}, Status ${status}`);
    // Implement actual DB logic here
  }
};

const EmailService = {
  notifyCustomer: async (customerEmail, subject, message) => {
    console.log(`Email sent to ${customerEmail}: ${subject} - ${message}`);
    // Implement real email sending here
  }
};

/**
 * Create a subscription for a customer with trial, coupon, and automatic payment handling
 */
async function createSubscription({
  customerId,
  priceId,
  organizationId,
  trialDays = 0,
  couponId,
}) {
  if (!customerId || !priceId) throw new Error('Customer ID and Price ID required');

  try {
    const subscriptionParams = {
      customer: customerId,
      items: [{ price: priceId }],
      payment_behavior: 'default_incomplete',
      expand: ['latest_invoice.payment_intent', 'customer'],
      metadata: organizationId ? { organization_id: organizationId } : undefined,
      // Automatic retry settings can also be configured in the Stripe Dashboard
    };

    if (trialDays > 0) subscriptionParams.trial_period_days = trialDays;
    if (couponId) subscriptionParams.coupon = couponId;

    const subscription = await stripe.subscriptions.create(subscriptionParams);
    const paymentIntent = subscription.latest_invoice?.payment_intent;

    if (paymentIntent && paymentIntent.status === 'requires_action') {
      return { subscription, clientSecret: paymentIntent.client_secret };
    }

    return { subscription };
  } catch (error) {
    console.error('Error creating subscription:', error.message);
    throw error;
  }
}

/**
 * Stripe webhook endpoint for subscription lifecycle events
 */
app.post('/webhook', express.raw({ type: 'application/json' }), async (req, res) => {
  const sig = req.headers['stripe-signature'];
  let event;

  try {
    event = stripe.webhooks.constructEvent(req.body, sig, process.env.STRIPE_WEBHOOK_SECRET);
  } catch (err) {
    console.error('Webhook signature verification failed:', err.message);
    return res.status(400).send(`Webhook Error: ${err.message}`);
  }

  const data = event.data.object;
  const customerEmail = data.customer_email || (data.customer?.email || 'unknown');

  switch (event.type) {
    case 'invoice.payment_succeeded':
      console.log('✅ Payment succeeded:', data.subscription);
      await Database.updateSubscriptionStatus(data.customer, data.subscription, 'active');
      await EmailService.notifyCustomer(customerEmail, 'Payment Successful', 'Your subscription payment was successful!');
      break;

    case 'invoice.payment_failed':
      console.log('❌ Payment failed:', data.subscription);
      await Database.updateSubscriptionStatus(data.customer, data.subscription, 'past_due');
      await EmailService.notifyCustomer(
        customerEmail,
        'Payment Failed',
        'Your subscription payment failed. Please update your payment method to avoid service interruption.'
      );
      break;

    case 'customer.subscription.deleted':
      console.log('⚠️ Subscription canceled:', data.id);
      await Database.updateSubscriptionStatus(data.customer, data.id, 'canceled');
      await EmailService.notifyCustomer(customerEmail, 'Subscription Canceled', 'Your subscription has been canceled.');
      break;

    case 'customer.subscription.updated':
      console.log('ℹ️ Subscription updated:', data.id, 'Status:', data.status);
      await Database.updateSubscriptionStatus(data.customer, data.id, data.status);
      break;

    default:
      console.log(`Unhandled event type: ${event.type}`);
  }

  res.json({ received: true });
});

// Example usage
(async () => {
  try {
    const { subscription, clientSecret } = await createSubscription({
      customerId: 'cus_xxxxxxxxxxxxx',
      priceId: 'price_xxxxxxxxxxxxx',
      organizationId: 'org_6RsNhnGbSQ3s7rFPAoYfQjA',
      trialDays: 14,
      couponId: 'coupon_xxxxx',
    });

    console.log('Subscription created:', subscription.id);
    if (clientSecret) console.log('Client action required (3DSecure):', clientSecret);
  } catch (err) {
    console.error('Failed to create subscription:', err);
  }
})();

const PORT = process.env.PORT || 4242;
app.listen(PORT, () => console.log(`Server running on port ${PORT}`));

